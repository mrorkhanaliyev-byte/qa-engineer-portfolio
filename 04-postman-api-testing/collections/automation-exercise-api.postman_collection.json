    {
      "name": "Search",
      "description": "Product search by free-text keyword. POST with form-encoded body.",
      "item": [
        {
          "name": "API 5 — POST /searchProduct (valid keyword)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "search_product",
                  "value": "{{searchKeyword}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPath}}/searchProduct",
              "host": ["{{baseUrl}}{{apiPath}}"],
              "path": ["searchProduct"]
            },
            "description": "Searches the catalog. Default keyword 'top' comes from the environment."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP status is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('responseCode in body is 200', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.responseCode).to.equal(200);",
                  "});",
                  "",
                  "pm.test('Body has products array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('products').that.is.an('array');",
                  "});",
                  "",
                  "pm.test('At least one result matches the keyword', () => {",
                  "  const body = pm.response.json();",
                  "  const keyword = pm.environment.get('searchKeyword').toLowerCase();",
                  "  const anyMatch = body.products.some(p =>",
                  "    (p.name || '').toLowerCase().includes(keyword) ||",
                  "    (p.category && JSON.stringify(p.category).toLowerCase().includes(keyword))",
                  "  );",
                  "  pm.expect(anyMatch, 'expected at least one product matching the keyword').to.be.true;",
                  "});"
                ]
              }
            }
          ]
        },
        {
