    {
      "name": "User Lifecycle (chained)",
      "description": "Create → fetch → update → delete a brand-new user. The pre-request script on the first request generates a unique timestamped email so the chain is fully idempotent across CI runs.\n\nIf any step fails, the cleanup step at the end still runs because each step has independent assertions — the chain doesn't short-circuit.",
      "item": [
        {
          "name": "API 11 — POST /createAccount",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Generate a unique email per run so the chain is idempotent.",
                  "const ts = Date.now();",
                  "pm.environment.set('createdUserEmail', `qa_chain_${ts}@portfolio.test`);",
                  "pm.environment.set('createdUserPassword', 'ChainTest@1234');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP status is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('responseCode in body is 201 (user created)', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.responseCode).to.equal(201);",
                  "});",
                  "",
                  "pm.test('Message confirms user creation', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect((body.message || '').toLowerCase()).to.include('created');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "name",            "value": "QA Chain User",              "type": "text"},
                {"key": "email",           "value": "{{createdUserEmail}}",       "type": "text"},
                {"key": "password",        "value": "{{createdUserPassword}}",    "type": "text"},
                {"key": "title",           "value": "Mr",                          "type": "text"},
                {"key": "birth_date",      "value": "15",                          "type": "text"},
                {"key": "birth_month",     "value": "June",                        "type": "text"},
                {"key": "birth_year",      "value": "1995",                        "type": "text"},
                {"key": "firstname",       "value": "QA",                          "type": "text"},
                {"key": "lastname",        "value": "Portfolio",                   "type": "text"},
                {"key": "company",         "value": "Portfolio Inc",               "type": "text"},
                {"key": "address1",        "value": "1 Test Lane",                 "type": "text"},
                {"key": "address2",        "value": "",                            "type": "text"},
                {"key": "country",         "value": "United States",               "type": "text"},
                {"key": "zipcode",         "value": "10001",                       "type": "text"},
                {"key": "state",           "value": "NY",                          "type": "text"},
                {"key": "city",            "value": "New York",                    "type": "text"},
                {"key": "mobile_number",   "value": "+15555550000",                "type": "text"}
              ]
            },
            "url": {
              "raw": "{{baseUrl}}{{apiPath}}/createAccount",
              "host": ["{{baseUrl}}{{apiPath}}"],
              "path": ["createAccount"]
            }
          }
        },
        {
          "name": "API 14 — GET /getUserDetailByEmail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}{{apiPath}}/getUserDetailByEmail?email={{createdUserEmail}}",
              "host": ["{{baseUrl}}{{apiPath}}"],
              "path": ["getUserDetailByEmail"],
              "query": [
                {"key": "email", "value": "{{createdUserEmail}}"}
              ]
            },
            "description": "Reads back the user we just created. Confirms the data persisted and is queryable."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('HTTP status is 200', () => {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('responseCode in body is 200', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.responseCode).to.equal(200);",
                  "});",
                  "",
                  "pm.test('Returned user matches the one we created', () => {",
                  "  const body = pm.response.json();",
