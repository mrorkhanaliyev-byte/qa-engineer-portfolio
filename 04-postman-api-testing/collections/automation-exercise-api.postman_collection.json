                  "});",
                  "",
                  "pm.test('responseCode in body is 200 (deleted)', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.responseCode).to.equal(200);",
                  "});",
                  "",
                  "pm.test('Message confirms account deletion', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect((body.message || '').toLowerCase()).to.include('deleted');",
                  "});",
